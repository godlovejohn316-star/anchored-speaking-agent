PORT=4174
NODE_ENV=development
DATA_DIR=./data
AI_PROVIDER=openai-realtime
OPENAI_API_KEY=sk-your-proxy-api-key
OPENAI_API_BASE=https://api.zyaihub.com/v1
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_TRANSPORT=websocket
OPENAI_REALTIME_SESSION_MODE=sdp-proxy
OPENAI_TEXT_MODEL=gpt-4o
OPENAI_VOICE=alloy

# Optional realtime mode, only if the provider confirms WebRTC support:
# AI_PROVIDER=openai-realtime
# OPENAI_REALTIME_MODEL=gpt-realtime-2
# OPENAI_VOICE=alloy

# Fallback domestic text mode:
DASHSCOPE_API_KEY=sk-your-dashscope-api-key
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus
PRACTICE_MAX_MINUTES=8
